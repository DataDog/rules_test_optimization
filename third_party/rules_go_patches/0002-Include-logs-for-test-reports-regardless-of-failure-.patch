-			if !reflect.DeepEqual(suites, tt.expected) {
-				t.Fatalf("expected %#v, got: %#v", tt.expected, suites)
+			if got := trimSuiteTestCases(suites); !reflect.DeepEqual(got, tt.expected) {
+				t.Fatalf("expected %#v, got: %#v", tt.expected, got)
 			}
+
