# Required on Windows for dd_topt_java_test: -javaagent paths only resolve under symlinked runfiles.
build --enable_runfiles

# Hermetic config (sandbox, stable env, network blocking)
build:hermetic --incompatible_strict_action_env
build:hermetic --spawn_strategy=sandboxed
test:hermetic --spawn_strategy=sandboxed --strategy=TestRunner=sandboxed
test:hermetic --sandbox_default_allow_network=false
test:hermetic --modify_execution_info=TestRunner=+block-network
test:hermetic --test_env=TZ=UTC
test:hermetic --test_env=LANG=C
test:hermetic --test_env=LC_ALL=C

# Uncomment and provide values via shell/CI secret store:
# common --repo_env=DD_API_KEY
# common --repo_env=DD_SITE

